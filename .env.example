# Copier vers .env et renseigner les valeurs (ne jamais committer .env)

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Indicatif pays par défaut pour numéros sans + (libphonenumber), ex. CD = RDC
# PHONE_DEFAULT_REGION=CD

# Origines CORS : URLs complètes avec schéma (pas de * seul ici). Exemples :
# CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
# Pour tout autoriser en dev : CORS_ALLOWED_ORIGINS=*  (converti en allow-all par settings)
# Ou explicitement : CORS_ALLOW_ALL_ORIGINS=true
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Optionnel : journalisation
DJANGO_LOG_LEVEL=INFO

# --- Base MySQL / MariaDB (XAMPP, WAMP, MySQL Workbench, etc.) ---
#
# Checklist si un clone ne peut pas migrer :
# 1) Base en utf8mb4 (obligatoire) :
#    CREATE DATABASE bdd_unilukaapp CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
# 2) Erreur 1071 « clé trop longue » : déjà prise en charge dans le code (VARCHAR 191 sur index uniques).
# 3) Erreur sql_mode / dates / strict : laisser la ligne suivante vide puis relancer migrate :
#    DB_INIT_COMMAND=
# 4) migrate a échoué à mi-parcours : supprimer toutes les tables Django dans la base (ou recréer la base vide), puis : py manage.py migrate
# 5) Mot de passe root MySQL : renseigner DB_PASSWORD dans .env (souvent vide sous WAMP, parfois défini).
# 6) Connexion : préférer DB_HOST=127.0.0.1 sous Windows (évite soucis IPv6 avec « localhost »).
#
# Les fichiers uploadés (horaires PDF/images, photos profil) utilisent des chemins jusqu’à 512 caractères en base.
#
DB_NAME=bdd_unilukaapp
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# Même backend pour MySQL et MariaDB ; ne changez que si vous savez pourquoi.
# DB_ENGINE=django.db.backends.mysql

# Connexions persistantes (0 = nouvelle connexion à chaque requête, souvent OK en dev)
# DB_CONN_MAX_AGE=0
# DB_CONN_HEALTH_CHECKS=false

# Fichier d’options client MySQL (optionnel, chemins absolus sous Windows)
# DB_READ_DEFAULT_FILE=

# Par défaut : SET sql_mode='STRICT_TRANS_TABLES'. Pour WAMP/MariaDB capricieux, désactiver avec une ligne vide :
# DB_INIT_COMMAND=
# DB_INIT_COMMAND=SET sql_mode='STRICT_TRANS_TABLES'

# Pilote Python : mysqlclient OU PyMySQL (souvent plus simple sous Windows avec XAMPP/WAMP).
