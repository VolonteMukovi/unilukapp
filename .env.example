# Copier vers .env et renseigner les valeurs (ne jamais committer .env)

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Indicatif pays par défaut pour numéros sans + (libphonenumber), ex. CD = RDC
# PHONE_DEFAULT_REGION=CD

# Origines CORS : URLs complètes avec schéma (pas de * seul ici). Exemples :
# CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
# Pour tout autoriser en dev : CORS_ALLOWED_ORIGINS=*  (converti en allow-all par settings)
# Ou explicitement : CORS_ALLOW_ALL_ORIGINS=true
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Optionnel : journalisation
DJANGO_LOG_LEVEL=INFO

# --- Base MySQL / MariaDB (XAMPP, WAMP, MySQL Server, MariaDB, etc.) ---
# Créez la base dans phpMyAdmin / Workbench : CREATE DATABASE bdd_unilukaapp CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
DB_NAME=bdd_unilukaapp
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# Même backend pour MySQL et MariaDB ; ne changez que si vous savez pourquoi.
# DB_ENGINE=django.db.backends.mysql

# Connexions persistantes (0 = nouvelle connexion à chaque requête, souvent OK en dev)
# DB_CONN_MAX_AGE=0
# DB_CONN_HEALTH_CHECKS=false

# Fichier d’options client MySQL (optionnel, chemins absolus sous Windows)
# DB_READ_DEFAULT_FILE=

# Désactiver sql_mode strict sur un serveur très ancien : DB_INIT_COMMAND=
# ou surcharger : DB_INIT_COMMAND=SET sql_mode='STRICT_TRANS_TABLES'

# Pilote Python : installez mysqlclient (performant) OU PyMySQL (pip simple, souvent utilisé avec XAMPP/WAMP).
# Si les deux sont absents, Django échouera à la connexion.
